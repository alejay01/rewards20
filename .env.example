# Server Configurations
NODE_ENV=production
PORT=3000
APP_URL=https://theboudincompany.com
CLIENT_URL=https://theboudincompany.com

# Database Connection (MySQL Production & XAMPP Local)
# You can supply either a full connection URL or individual MYSQL parameters
DATABASE_URL=mysql://root:@127.0.0.1:3306/rewards20
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=rewards20
MYSQL_USER=root
MYSQL_PASSWORD=

# Session & Token Secrets
SESSION_SECRET=boudin-boss-rewards-session-secret-key-2026!
JWT_SECRET=boudin-boss-rewards-secret-key-2026!
QR_TOKEN_SECRET=boudin-boss-rewards-qr-cryptography-key-2026!

# Loyverse API Integration
LOYVERSE_API_KEY=
LOYVERSE_API_BASE_URL=https://api.loyverse.com/v1.0
LOYVERSE_DEMO_MODE=true
