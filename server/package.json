{
  "name": "rewards-server",
  "version": "1.0.0",
  "description": "Express backend for Boudin Boss Rewards",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npm run copy-public",
    "copy-public": "node -e \"const fs = require('fs'); if (fs.existsSync('public')) { fs.cpSync('public', 'dist/public', { recursive: true }); }\"",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/createDb.ts && drizzle-kit generate && tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.9.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.12",
    "drizzle-kit": "^0.21.4",
    "tsx": "^4.10.1",
    "typescript": "^5.4.5"
  }
}
